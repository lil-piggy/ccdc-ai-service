DATABASE_URL=postgresql://user:password@localhost:5432/ccdc_db
JWT_SECRET=your-jwt-secret-change-me

# 主 LLM API（OpenAI 兼容格式）
ADMIN_API_URL=https://api.moonshot.cn/v1
ADMIN_API_KEY=sk-your-key
ADMIN_API_MODEL=kimi-k2.6
ADMIN_API_MODELS=kimi-k2.6|Kimi K2.6,deepseek-v4-pro|DeepSeek V4 Pro

# 知识库 Embedding API（OpenAI 兼容格式）
EMBEDDING_API_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=sk-your-embedding-key
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# 知识库分块与检索配置
KB_CHUNK_SIZE=500
KB_CHUNK_OVERLAP=100
KB_TOP_K=5
