# 服务端口号（Render 会自动注入 PORT）
PORT=3000

# 数据库文件路径（本地开发默认使用项目目录下的 data.sqlite）
# 在 Render 部署时，已通过 render.yaml 配置为 /var/lib/ccdc/data.sqlite（持久化磁盘）
DB_PATH=./data.sqlite

# JWT 密钥（必须修改为一个随机长字符串，至少32位）
# 警告：部署后请勿随意修改，否则所有已登录用户的 Token 会失效
JWT_SECRET=your-super-secret-jwt-key-change-this

# 管理员统一配置的 OpenAI 兼容 API
ADMIN_API_URL=https://api.moonshot.cn/v1/chat/completions
ADMIN_API_KEY=sk-your-api-key-here

# 默认模型列表（格式：模型ID|显示名称,模型ID|显示名称）
# 默认已配置 Kimi K2.6 和 DeepSeek V4 Pro 两个模型
ADMIN_API_MODELS=kimi-k2.6|Kimi K2.6,deepseek-v4-pro|DeepSeek V4 Pro

# 兼容旧版单模型配置（如未设置 ADMIN_API_MODELS 则使用以下配置）
# ADMIN_API_MODEL=kimi-k2.6
# ADMIN_MODEL_LABEL=Kimi K2.6
